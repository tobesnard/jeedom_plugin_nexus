{
    "name": "jeedom/rule-interpreter",
    "description": "Système d'interprétation de règles pour Jeedom - Un interpréteur flexible utilisant le pattern GoF Interpreter",
    "type": "library",
    "keywords": [
        "jeedom",
        "interpreter",
        "rules",
        "automation",
        "expression",
        "parser"
    ],
    "license": "GPL-3.0-or-later",
    "version": "1.0.0",
    "authors": [
        {
            "name": "Tony",
            "email": "tobesnard@gmail.com",
            "role": "Developer"
        }
    ],
    "autoload": {
        "psr-4": {
            "Nexus\\Interpreter\\": "core/class"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Interpreter\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=7.4",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "phpstan/phpstan": "^1.0",
        "squizlabs/php_codesniffer": "^3.6",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage/",
        "analyse": "phpstan analyse src --level max",
        "cs-check": "phpcs src --standard=PSR12",
        "cs-fix": "php-cs-fixer fix src",
        "quality": [
            "@cs-check",
            "@analyse",
            "@test"
        ]
    },
    "scripts-descriptions": {
        "test": "Lance les tests unitaires",
        "test-coverage": "Lance les tests avec rapport de couverture",
        "analyse": "Analyse statique du code avec PHPStan",
        "cs-check": "Vérifie le style de code PSR-12",
        "cs-fix": "Corrige automatiquement le style de code",
        "quality": "Lance tous les contrôles qualité"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform-check": false
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
