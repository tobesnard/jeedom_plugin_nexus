{
    "autoload": {
        "psr-4": {
            "Nexus\\": "core/class",
            "Nexus\\HueSync\\": "packages/huesync/core/class/",
            "Nexus\\Interpreter\\": "packages/interpreter/core/class",
            "Nexus\\Multimedia\\PhilipsTV\\": "packages/philips_tv/core/class",
            "Nexus\\Multimedia\\WakeUpCall\\": "packages/wake_up_call/core/class",
            "Nexus\\Energy\\Electricity\\": "packages/energy_consumption/core/class",
            "Nexus\\AI\\AIClient\\": "packages/ai_client/core/class",
            "Nexus\\Openings\\": "packages/openings/core/class",
            "Nexus\\Jeedom\\": "packages/jeedom/core/class",
            "Nexus\\Utils\\": "packages/utils/core/class",
            "Nexus\\Alarm\\": "packages/alarm/core/class",
            "Nexus\\Monitoring\\": "packages/monitoring/core/class",
            "Nexus\\Cloud\\": "packages/cloud/core/class",
            "Nexus\\Communication\\": "packages/communication/core/class",
            "Nexus\\Security\\Camera\\": "packages/reolink/core/class"
        },
        "classmap": [
            "packages/wake_up_call/3rdparty/cast/"
        ],
        "files": [
            "core/config/bootstrap.php"
        ]
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "config": {
        "process-timeout": 1800
    },
    "scripts": {
        "cs-fix": "php-cs-fixer fix",
        "test-aiclient": "phpunit packages/ai_client/tests/",
        "test-jeedom": "phpunit packages/jeedom/tests/",
        "test-monitoring": "phpunit packages/monitoring/tests/",
        "test-alarm": "phpunit packages/alarm/tests/",
        "demo-energy-core": "php packages/energy_consumption/tests/demo.core.php",
        "demo-energy-inc": "php packages/energy_consumption/tests/demo.inc.php",
        "demo-interpret-core": "php packages/interpreter/tests/demo.core.php",
        "demo-interpret-core-mocked": "php packages/interpreter/tests/demo.core.mocked.php",
        "demo-huesync-core": "python3 packages/huesync/tests/demo.core.py",
        "demo-huesync-inc": "php packages/huesync/tests/demo.inc.php",
        "demo-philipstv-inc": "php packages/philips_tv/tests/demo.inc.php",
        "demo-philipstv-core": "python3 packages/philips_tv/tests/demo.core.py",
        "demo-wakeupcall-inc": "php packages/wake_up_call/tests/demo.inc.php",
        "demo-wakeupcall-core": "php packages/wake_up_call/tests/demo.core.php",
        "demo-openings-core": "php packages/openings/tests/demo.core.php",
        "demo-openings-inc": "php packages/openings/tests/demo.inc.php",
        "demo-jeedom-core": "php packages/jeedom/tests/demo.core.php",
        "demo-jeedom-inc": "php packages/jeedom/tests/demo.inc.php",
        "demo-aiclient-core": "php packages/ai_client/tests/demo.core.php",
        "demo-aiclient-inc": "php packages/ai_client/tests/demo.inc.php",
        "demo-utils-core": "php packages/utils/tests/utils.core.php",
        "demo-utils-inc": "php packages/utils/tests/utils.inc.php",
        "demo-monitoring-core": "php packages/monitoring/tests/monitoring.core.php",
        "demo-alarm-core": "php packages/alarm/tests/alarm.core.php",
        "demo-cloud-inc": "php packages/cloud/tests/cloud.inc.php",
        "demo-cloud-core": "php packages/cloud/tests/cloud.core.php"
    },
    "require": {
        "vlucas/phpdotenv": "^5.6",
        "guzzlehttp/guzzle": "^7.0"
    }
}
